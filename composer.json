{
    "name": "facevault/facevault-identity-verification",
    "description": "Development tooling for the FaceVault Identity Verification WordPress plugin. The shipped plugin has zero runtime Composer dependencies.",
    "license": "GPL-2.0-or-later",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "7.4.33"
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs",
        "test": "phpunit"
    }
}
